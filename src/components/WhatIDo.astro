---
const skills = [
  {
    title: "Frontend Development",
    description:
      "Building responsive, performant UIs with React, Vue, Angular, Next.js, and TypeScript. Experienced with Tailwind CSS, Bootstrap, and component libraries.",
    icon: "layout",
  },
  {
    title: "Backend Development",
    description:
      "Designing scalable APIs and services with Node.js, Express.js, and serverless architectures on AWS and GCP.",
    icon: "server",
  },
  {
    title: "Database & Cloud",
    description:
      "Working with MongoDB, AWS (Lambda, AppSync), Google Cloud Platform, and Azure for reliable, cloud-native solutions.",
    icon: "cloud",
  },
  {
    title: "Full-Stack Solutions",
    description:
      "Delivering end-to-end web applications — from UI design to deployment — in agile teams for startups and enterprise clients.",
    icon: "code",
  },
];
---

<section class="border-t border-border bg-bg-secondary dark:border-border-dark dark:bg-bg-secondary-dark">
  <div class="mx-auto max-w-5xl px-6 py-20 md:py-28">
    <!-- Section header -->
    <div class="mb-12">
      <p
        class="text-sm font-medium tracking-widest uppercase text-primary dark:text-primary-dark"
      >
        What I Do
      </p>
      <h2
        class="mt-2 text-3xl font-bold text-(--color-text) dark:text-text-dark"
      >
        Skills & Services
      </h2>
    </div>

    <!-- Skills grid -->
    <div class="grid gap-6 sm:grid-cols-2">
      {
        skills.map((skill) => (
          <div class="group rounded-xl border border-border bg-bg p-6 transition-all duration-200 hover:border-primary/30 hover:shadow-md dark:border-border-dark dark:bg-(--color-bg-dark) dark:hover:border-primary-dark/30">
            {/* Icon */}
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 dark:bg-primary-dark/10">
              {skill.icon === "layout" && (
                <svg
                  class="h-5 w-5 text-primary dark:text-primary-dark"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"
                  />
                </svg>
              )}
              {skill.icon === "server" && (
                <svg
                  class="h-5 w-5 text-primary dark:text-primary-dark"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"
                  />
                </svg>
              )}
              {skill.icon === "cloud" && (
                <svg
                  class="h-5 w-5 text-primary dark:text-primary-dark"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"
                  />
                </svg>
              )}
              {skill.icon === "code" && (
                <svg
                  class="h-5 w-5 text-primary dark:text-primary-dark"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"
                  />
                </svg>
              )}
            </div>

            {/* Content */}
            <h3 class="text-lg font-semibold text-(--color-text) dark:text-text-dark">
              {skill.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary dark:text-text-secondary-dark">
              {skill.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Tech stack tags -->
    <div class="mt-12">
      <p
        class="mb-4 text-sm font-medium text-text-secondary dark:text-text-secondary-dark"
      >
        Technologies I work with:
      </p>
      <div class="flex flex-wrap gap-2">
        {
          [
            "React",
            "Vue.js",
            "Angular",
            "Next.js",
            "Nuxt.js",
            "TypeScript",
            "Node.js",
            "Express.js",
            "MongoDB",
            "AWS",
            "GCP",
            "Tailwind CSS",
            "Git",
            "Figma",
          ].map((tech) => (
            <span class="rounded-full border border-border bg-bg px-3 py-1 text-xs font-medium text-text-secondary transition-colors dark:border-border-dark dark:bg-(--color-bg-dark) dark:text-text-secondary-dark">
              {tech}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
